TENNIS_ENV=dev
TENNIS_RUN_ROOT=runs/tennis
TENNIS_SOURCE_ADAPTER=generic_csv
TENNIS_SCHEDULE_SOURCE_URI=/absolute/path/to/schedule.csv
TENNIS_ODDS_SOURCE_URI=/absolute/path/to/odds.csv
# For live tennis odds via The Odds API:
# TENNIS_SOURCE_ADAPTER=odds_api_tennis
# ODDS_API_KEY=your_odds_api_key_here
# TENNIS_ODDS_API_BOOKMAKERS=draftkings,fanduel,betmgm,caesars,bet365,fanatics
# TENNIS_ODDS_API_REGIONS=us
# TENNIS_ODDS_API_SPORT_KEYS=tennis_atp_madrid_open
TENNIS_PROMOTED_BUNDLE_DIR=data/tennis/model/promoted/current
TENNIS_MATCH_DB_PATH=data/tennis/features/matches.parquet
TENNIS_RANKINGS_PATH=data/tennis/features/rankings.parquet
TENNIS_TIMEZONE=America/Denver
TENNIS_SCHEDULE_MAX_AGE_HOURS=30
TENNIS_ODDS_MAX_AGE_HOURS=30
TENNIS_MIN_FEATURE_COVERAGE=0.65
TENNIS_MIN_ODDS_MATCH_CONFIDENCE=0.75
TENNIS_OUTPUT_BUCKET=
TENNIS_UPLOAD_TO_GCS=false
TENNIS_NOTIFICATION_WEBHOOK=
